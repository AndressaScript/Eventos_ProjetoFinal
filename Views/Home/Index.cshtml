@{
    ViewData["Title"] = "Home Page";
}

@section Styles {
    <link rel="stylesheet" href="~/css/home.css">
}

@section Scripts {
    <script src="~/js/home.js"></script>
}

    <section class="hero-section">
        <div class="container hero-container">
            <div class="hero-content">
                <h1>SENAI: Conectando Você ao Futuro. Participe de Nossos Eventos.</h1>
                <a href="#" class="btn btn-primary">Ver Agenda Completa</a>
            </div>
            <div class="hero-image">
                <img src="../img/Banner.png" alt="Estudantes SENAI">
            </div>
        </div>
    </section>

    <section class="events-section">
        <div class="container events-grid">
            
            <div class="event-card">
                <div class="card-img">
                    <img src="https://images.unsplash.com/photo-1608962714006-299d12f455a0?auto=format&fit=crop&w=400&q=80" alt="Robótica">
                </div>
                <div class="card-body">
                    <h3>Workshop de Robótica Industrial</h3>
                    <p class="event-date">22 de agosto de 2026 às 15h</p>
                    <p class="event-desc">Workshop de impressão 3D e prototipagem...</p>
                    <a href="#" class="btn btn-card">Inscrever-se</a>
                </div>
            </div>

            <div class="event-card">
                <div class="card-img">
                    <img src="https://images.unsplash.com/photo-1518770660439-4636190af475?auto=format&fit=crop&w=400&q=80" alt="IoT">
                </div>
                <div class="card-body">
                    <h3>Inovação em IoT</h3>
                    <p class="event-date">07 Outubro de 2026 às 16h</p>
                    <p class="event-desc">Workshop de como trabalhar com IoT dentro do mercado de Trabalho</p>
                    <a href="#" class="btn btn-card">Inscrever-se</a>
                </div>
            </div>

            <div class="event-card">
                <div class="card-img">
                    <img src="https://images.unsplash.com/photo-1677442136019-21780efad99a?auto=format&fit=crop&w=400&q=80" alt="IA">
                </div>
                <div class="card-body">
                    <h3>Palestra de como a IA pode ser Aliada</h3>
                    <p class="event-date">15 de Novembro de 2026 às 19h</p>
                    <p class="event-desc">Palestra abordando os impactos positivos da IA no dia a dia de um DEV</p>
                    <a href="#" class="btn btn-card">Inscrever-se</a>
                </div>
            </div>

        </div>
    </section>

    <main class="container main-content">
        
        <section class="gallery-section">
            <h2>Fotografias de Eventos Anteriores</h2>
            <div class="photo-collage">
                <div class="photo-item large"><img src="https://images.unsplash.com/photo-1523240795612-9a054b0db644?auto=format&fit=crop&w=500&q=80" alt="Formatura"></div>
                <div class="photo-item"><img src="https://images.unsplash.com/photo-1531482615713-2afd69097998?auto=format&fit=crop&w=300&q=80" alt="Estudantes trabalhando"></div>
                <div class="photo-item"><img src="https://images.unsplash.com/photo-1522202176988-66273c2fd55f?auto=format&fit=crop&w=300&q=80" alt="Reunião"></div>
                <div class="photo-item"><img src="https://images.unsplash.com/photo-1556761175-4b46a572b786?auto=format&fit=crop&w=300&q=80" alt="Apresentação"></div>
            </div>
        </section>

        <aside class="impacts-section">
            <div class="section-title-line"></div>
            <h2>Nossos Impactos</h2>
            <p>Milhares de profissionais qualificados e ......</p>
        </aside>

    </main>

    <section class="container calendar-section">
        <div class="section-title-line"></div>
        <h2>Próximas Datas Importantes</h2>
    </section>

    <footer class="main-footer">
        <div class="container footer-grid">
            <div class="footer-logo">SENAI</div>
            
            <div class="footer-contact">
                <p><i class="fa-solid fa-phone"></i> (11) 8754-8291</p>
                <p><i class="fa-solid fa-envelope"></i> senai@email.com</p>
                <p><i class="fa-solid fa-globe"></i> www.aluno.senai.br</p>
            </div>
            
            <div class="footer-address">
                <p><i class="fa-solid fa-location-dot"></i> Rua Niterói - 180</p>
                <p>Centro, São Caetano do Sul - SP</p>
                <p>CEP: 09510-200</p>
            </div>
            
            <div class="footer-links">
                <a href="#">Política de Privacidade</a>
                <a href="#">Perguntas Frequentes</a>
                <a href="#">Centro de Eventos</a>
            </div>
        </div>
    </footer>
