@model IEnumerable<Eventos_ProjetoFinal.Models.Eventos>
@{
    ViewData["Title"] = Context.Session.GetString("Role") == "Admin" ? "Painel de Controle - SENAI" : "Portal de Eventos SENAI";
}
@section Styles {
    <link rel="stylesheet" href="~/css/home.css" asp-append-version="true">
    <!-- CSS DO CHATBOT INJETADO -->
    <link rel="stylesheet" href="~/css/chatbot.css" asp-append-version="true">
}
@section Scripts {
    <script src="~/js/home.js" asp-append-version="true"></script>
    <!-- JS DO CHATBOT INJETADO -->
    <script src="~/js/chatbot.js" asp-append-version="true"></script>
}

@if (Context.Session.GetString("Role") == "Admin")
{
    <!-- =================================================================
         PAINEL DE CONTROLE DO ADMINISTRADOR (NOVA HOME DO ADMIN)
         ================================================================= -->
    <!-- Header Administrativo -->
    <header class="header">
        <div class="header-container">
            <div class="logo-container">
                <a asp-controller="Home" asp-action="Index">
                    <img class="logo-senai" src="~/img/Senai_logo_footer.png" alt="Logo SENAI">
                </a>
            </div>
            <nav class="nav-menu">
                <a asp-controller="Home" asp-action="Index" class="active">Painel Geral</a>
                <a asp-controller="Eventos" asp-action="Index">Gerenciar Eventos</a>
                <a asp-controller="Eventos" asp-action="Cadastrar">Cadastrar Evento</a>
                <a asp-controller="Eventos" asp-action="Galeria">Galeria</a>
            </nav>
            <div class="header-actions">
                <span class="user-email" style="font-weight: 600;"><i class="fa-solid fa-circle-user"></i> Admin</span>
                <a asp-controller="Login" asp-action="Logout" class="btn-logout" title="Sair"><i class="fa-solid fa-right-from-bracket"></i> Sair</a>
            </div>
        </div>
    </header>

    <section class="admin-home-section" style="padding-top: 140px; padding-bottom: 80px; min-height: 100vh;">
        <div class="admin-home-container" style="max-width: 1300px; margin: 0 auto; padding: 0 2rem; width: 100%;">
           
            <div class="admin-welcome-banner">
                <div class="welcome-left">
                    <span class="welcome-tag">PORTAL ADMINISTRATIVO</span>
                    <h1>Bem-vindo ao Painel de Controle, <span class="highlight-text">Administrador!</span></h1>
                    <p>Aqui você monitora os seus eventos, o engajamento dos alunos, e publica imagens na galeria de eventos.</p>
                </div>
            </div>

            <!-- Grade de Estatísticas em Tempo Real -->
            <h2 class="admin-section-title"><i class="fa-solid fa-chart-simple"></i> Estatísticas do Sistema</h2>
            <div class="admin-stats-grid">
                <div class="admin-stat-card card-blue-glow">
                    <div class="stat-icon"><i class="fa-regular fa-calendar-check"></i></div>
                    <div class="stat-info">
                        <h3>@ViewBag.TotalEventos</h3>
                        <p>Total de Eventos</p>
                    </div>
                </div>
               
                <div class="admin-stat-card card-purple-glow">
                    <div class="stat-icon"><i class="fa-solid fa-user-graduate"></i></div>
                    <div class="stat-info">
                        <h3>@ViewBag.TotalAlunos</h3>
                        <p>Alunos Cadastrados</p>
                    </div>
                </div>

                <div class="admin-stat-card card-pink-glow">
                    <div class="stat-icon"><i class="fa-solid fa-file-signature"></i></div>
                    <div class="stat-info">
                        <h3>@ViewBag.TotalInscricoes</h3>
                        <p>Inscrições Realizadas</p>
                    </div>
                </div>

                <div class="admin-stat-card card-cyan-glow">
                    <div class="stat-icon"><i class="fa-regular fa-comment-dots"></i></div>
                    <div class="stat-info">
                        <h3>@ViewBag.TotalAvaliacoes</h3>
                        <p>Comentários & Avaliações</p>
                    </div>
                </div>
            </div>

            <!-- Grade de Ações Rápidas -->
            <h2 class="admin-section-title" style="margin-top: 3rem;"><i class="fa-solid fa-gears"></i> Ações Rápidas de Gestão</h2>
            <div class="admin-actions-grid">
                <div class="admin-action-card">
                    <div class="action-card-icon icon-blue"><i class="fa-solid fa-table-cells-large"></i></div>
                    <h3>Gestão de Eventos</h3>
                    <p>Visualize a tabela geral de eventos cadastrados, ative ou desative o status de eventos e exclua registros indesejados.</p>
                    <a asp-controller="Eventos" asp-action="Index" class="btn-action-go">Acessar Painel <i class="fa-solid fa-arrow-right"></i></a>
                </div>

                <div class="admin-action-card">
                    <div class="action-card-icon icon-purple"><i class="fa-solid fa-calendar-plus"></i></div>
                    <h3>Cadastrar Evento</h3>
                    <p>Publique novos eventos na agenda. Defina data, hora, palestrante convidado, local do evento e capacidade máxima de alunos.</p>
                    <a asp-controller="Eventos" asp-action="Cadastrar" class="btn-action-go">Novo Evento <i class="fa-solid fa-arrow-right"></i></a>
                </div>

                <div class="admin-action-card">
                    <div class="action-card-icon icon-pink"><i class="fa-regular fa-images"></i></div>
                    <h3>Gerenciar Galeria</h3>
                    <p>Acompanhe a memória visual dos eventos passados. Veja a galeria completa e gerencie os registros históricos do centro.</p>
                    <a asp-controller="Eventos" asp-action="Galeria" class="btn-action-go">Acessar Galeria <i class="fa-solid fa-arrow-right"></i></a>
                </div>
            </div>
        </div>
    </section>

    <footer class="footer-new" style="padding: 40px 0; border-top: 1px solid var(--border-glow);">
        <div style="max-width: 1300px; margin: 0 auto; padding: 0 2rem; display: flex; justify-content: space-between; align-items: center; color: var(--text-light-muted); font-size: 0.9rem;">
            <span>&copy; 2026 Portal de Eventos SENAI - Painel de Controle</span>
            <span>Administrador Autenticado</span>
        </div>
    </footer>
}
else
{
    <!-- =================================================================
         PORTAL PÚBLICO (ALUNOS E VISITANTES)
         ================================================================= -->
    <!-- Header -->
    <header class="header">
        <div class="header-container">
            <div class="logo-container">
                <a asp-controller="Home" asp-action="Index">
                    <img class="logo-senai" src="~/img/Senai_logo_footer.png" alt="Logo SENAI">
                </a>
            </div>
            <nav class="nav-menu">
                <a href="#eventos">Eventos</a>
                <a href="#sobre">Sobre o Centro</a>
                <a href="#impactos">Impactos</a>
                <a asp-controller="Eventos" asp-action="Galeria">Galeria</a>
                <a href="#contato">Contato</a>
            </nav>
            <div class="header-actions">
                @if (Context.Session.GetString("UsuarioId") != null)
                {
                    <span class="user-email">@Context.Session.GetString("Email")</span>
                    <a asp-controller="Login" asp-action="Logout" class="btn-logout" title="Sair"><i class="fa-solid fa-right-from-bracket"></i> Sair</a>
                }
                else
                {
                    <a asp-controller="Login" asp-action="Index" class="btn-agenda-header" title="Login"><i class="fa-regular fa-user"></i> Login </a>
                }
            </div>
        </div>
    </header>

    <!-- Hero Section -->
    <section class="hero-section">
        <div class="hero-container">
            <div class="hero-content-left">
                <div class="hero-tag">
                    <span class="tag-text">EVENTOS SENAI</span>
                    <span class="tag-line"></span>
                </div>
                <h1 class="hero-title">CONECTANDO VOCÊ AO <span class="highlight-text">FUTURO.</span></h1>
                <p class="hero-subtitle">Participe de experiências que transformam conhecimento em oportunidades reais.</p>
                <div class="hero-buttons">
                    <a href="#eventos" class="btn-primary-gradient">Explorar Agenda <i class="fa-regular fa-calendar"></i></a>
                </div>
            </div>
        </div>

        <div class="hero-highlights">
            <div class="highlight-card">
                <div class="highlight-icon"><i class="fa-solid fa-laptop-code"></i></div>
                <div class="highlight-text">
                    <h3>Experiências práticas</h3>
                    <p>Aprenda além da sala de aula.</p>
                </div>
            </div>
            <div class="highlight-card">
                <div class="highlight-icon"><i class="fa-solid fa-users"></i></div>
                <div class="highlight-text">
                    <h3>Networking profissional</h3>
                    <p>Conecte-se com empresas e especialistas.</p>
                </div>
            </div>
            <div class="highlight-card">
                <div class="highlight-icon"><i class="fa-solid fa-microchip"></i></div>
                <div class="highlight-text">
                    <h3>Tecnologia e inovação</h3>
                    <p>Contato com tendências do mercado.</p>
                </div>
            </div>
            <div class="highlight-card">
                <div class="highlight-icon"><i class="fa-solid fa-chart-line"></i></div>
                <div class="highlight-text">
                    <h3>Crescimento de carreira</h3>
                    <p>Oportunidades para seu desenvolvimento.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Seção Próximos Eventos -->
    <section id="eventos" class="events-section">
        <div class="section-header-row">
            <div class="section-title-block">
                <span class="section-tag-purple">PRÓXIMOS EVENTOS</span>
                <h2 class="section-title-dark">Aprenda. Conecte-se. Transforme.</h2>
            </div>
            <a asp-controller="Home" asp-action="Todos" class="btn-outline-blue">Ver todos os eventos <i class="fa-solid fa-arrow-up-right-from-square"></i></a>
        </div>

        @if (TempData["Sucesso"] != null)
        {
            <div class="alert alert-success" style="max-width: 1300px; margin: 0 auto 20px auto; width: calc(100% - 4rem);">@TempData["Sucesso"]</div>
        }
        @if (TempData["Erro"] != null)
        {
            <div class="alert alert-danger" style="max-width: 1300px; margin: 0 auto 20px auto; width: calc(100% - 4rem);">@TempData["Erro"]</div>
        }

        <!-- Carrossel de Eventos -->
        <div class="carousel-container-new">
            <button class="carousel-btn prev-btn" id="prevBtn" type="button" disabled>
                <i class="fa-solid fa-chevron-left"></i>
            </button>
           
            <div class="carousel-viewport-new">
                <div class="carousel-track-new" id="carouselTrack">
                    @if (Model != null && Model.Any())
                    {
                        @foreach (var item in Model)
                        {
                            bool isInscrito = false;
                            if (Context.Session.GetString("Role") == "Aluno" && ViewBag.InscritosIds != null)
                            {
                                isInscrito = ((List<int>)ViewBag.InscritosIds).Contains(item.EventoID);
                            }

                            string category = item.TipoEvento.ToUpper();
                            string badgeClass = category == "WORKSHOP" ? "badge-blue" : "badge-purple";
                           
                            string defaultImage = category == "WORKSHOP" ? "card_workshop.png" : "card_palestra.png";
                            if (item.NomeEvento.Contains("IoT", StringComparison.OrdinalIgnoreCase)) defaultImage = "card_IOT.png";

                            string imageSrc = string.IsNullOrEmpty(item.ImagemUrl)
                                ? Url.Content("~/img/" + defaultImage)
                                : item.ImagemUrl;

                            <div class="event-card-new carousel-item-new event-card-clickable"
                                 data-id="@item.EventoID"
                                 data-nome="@item.NomeEvento"
                                 data-data="@item.DataEvento.ToString("dd/MM/yyyy")"
                                 data-data-formatada="@item.DataEvento.ToString("dd 'de' MMMM 'de' yyyy")"
                                 data-hora="@item.HorarioEvento.ToString("HH:mm")"
                                 data-hora-formatada="às @item.HorarioEvento.ToString("HH'h'")"
                                 data-local="@item.LocalEvento"
                                 data-palestrante="@item.NomePalestrante"
                                 data-imagem="@imageSrc"
                                 data-descricao="@(string.IsNullOrEmpty(item.Descricao) ? "Sem descrição disponível para este evento." : item.Descricao)"
                                 data-inscrito="@(isInscrito ? "true" : "false")"
                                 data-tipo="@item.TipoEvento"
                                 data-role="@(Context.Session.GetString("Role") ?? "")">
                               
                                <div class="card-image-wrapper">
                                    <img src="@imageSrc" alt="@item.NomeEvento">
                                    <span class="category-badge @badgeClass">@category</span>
                                </div>
                               
                                <div class="card-content">
                                    <div class="event-header">
                                        <div class="date-badge">
                                            <span class="date-day">@item.DataEvento.ToString("dd")</span>
                                            <span class="date-month">@item.DataEvento.ToString("MMM").ToUpper()</span>
                                        </div>
                                        <div class="event-title">
                                            <h3>@item.NomeEvento</h3>
                                            <div class="event-meta">
                                                <span class="event-time">
                                                    <i class="fa-regular fa-clock"></i>
                                                    às @item.HorarioEvento.ToString("HH:mm")
                                                </span>
                                            </div>
                                        </div>
                                    </div>
                                    <p class="event-description">
                                        @(string.IsNullOrEmpty(item.Descricao) ? "Participe deste incrível evento integrado do SENAI." : (item.Descricao.Length > 85 ? item.Descricao.Substring(0, 82) + "..." : item.Descricao))
                                    </p>
                                    <p class="event-description" style="font-weight: 500; margin-top: auto;">Palestrante: @item.NomePalestrante | Local: @item.LocalEvento</p>
                                </div>
                               
                                <div class="card-footer-action">
                                    @if (isInscrito)
                                    {
                                        <span class="btn-subscribe-disabled" style="display: block; text-align: center; color: #22c55e; font-weight: bold;"><i class="fa-solid fa-circle-check"></i> Inscrito</span>
                                    }
                                    else
                                    {
                                        <button type="button" class="btn-subscribe-link btn-enroll-trigger">
                                            <span>Saber mais</span> <i class="fa-solid fa-arrow-right"></i>
                                        </button>
                                    }
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <p class="no-events">Nenhum evento ativo no momento.</p>
                    }
                </div>
            </div>
           
            <button class="carousel-btn next-btn" id="nextBtn" type="button">
                <i class="fa-solid fa-chevron-right"></i>
            </button>
        </div>
    </section>

    <!-- Seção Galeria & Estatísticas -->
    <section id="impactos" class="gallery-stats-section">
        <div class="gallery-stats-container">
            <!-- Esquerda: Galeria -->
            <div id="galeria" class="gallery-block">
                <span class="section-tag-cyan">MOMENTOS QUE MARCAM</span>
                <div class="gallery-header-row">
                    <h2 class="section-title-white">Eventos anteriores</h2>
                    <a asp-controller="Eventos" asp-action="Galeria" class="btn-outline-white"><i class="fa-regular fa-images"></i> Ver galeria completa</a>
                </div>
                <div class="gallery-grid-new">
                    <div class="gallery-item"><img src="~/img/galeria_eventos_1.png" alt="Evento 1"></div>
                    <div class="gallery-item"><img src="~/img/galeria_eventos_2.png" alt="Evento 2"></div>
                    <div class="gallery-item"><img src="~/img/galeria_eventos_3.png" alt="Evento 3"></div>
                    <div class="gallery-item"><img src="~/img/galeria_eventos_4.png" alt="Evento 4"></div>
                </div>
            </div>

            <!-- Direita: Números -->
            <div id="sobre" class="stats-block">
                <span class="section-tag-cyan">IMPACTO QUE TRANSFORMA</span>
                <h2 class="section-title-white">Nossos números falam por nós</h2>
                <div class="stats-list">
                    <div class="stat-item">
                        <div class="stat-icon-wrapper blue-icon"><i class="fa-solid fa-user-graduate"></i></div>
                        <div class="stat-text">
                            <span class="stat-number">+12.000</span>
                            <span class="stat-label">Profissionais qualificados</span>
                        </div>
                    </div>
                    <div class="stat-item">
                        <div class="stat-icon-wrapper purple-icon"><i class="fa-regular fa-calendar-check"></i></div>
                        <div class="stat-text">
                            <span class="stat-number">+210</span>
                            <span class="stat-label">Eventos realizados</span>
                        </div>
                    </div>
                    <div class="stat-item">
                        <div class="stat-icon-wrapper pink-icon"><i class="fa-solid fa-chart-line"></i></div>
                        <div class="stat-text">
                            <span class="stat-number">+95%</span>
                            <span class="stat-label">Índice de satisfação</span>
                        </div>
                    </div>
                    <div class="stat-item">
                        <div class="stat-icon-wrapper cyan-icon"><i class="fa-solid fa-handshake"></i></div>
                        <div class="stat-text">
                            <span class="stat-number">+150</span>
                            <span class="stat-label">Empresas parceiras</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="cta-banner">
            <div class="cta-left">
                <div class="cta-icon"><i class="fa-solid fa-rocket"></i></div>
                <h3>O futuro se constrói hoje. Participe dos nossos eventos!</h3>
            </div>
            <a href="#eventos" class="btn-primary-gradient cta-btn">Quero me inscrever <i class="fa-solid fa-arrow-up-right-from-square"></i></a>
        </div>
    </section>

    <!-- Footer -->
    <footer id="contato" class="footer-new">
        <div class="footer-grid">
            <div class="footer-col brand-col">
                <img src="~/img/Senai_logo_footer.png" alt="Logo SENAI" class="footer-logo">
                <p class="footer-desc">Educando hoje, transformando o amanhã.</p>
                <div class="social-icons">
                    <a href="https://www.instagram.com/senai.sp/"><i class="fa-brands fa-instagram"></i></a>
                    <a href="https://br.linkedin.com/company/senai-nacional"><i class="fa-brands fa-linkedin"></i></a>
                    <a href="https://www.youtube.com/channel/UCaz1BMUVug86pd_uS598X1A"><i class="fa-brands fa-youtube"></i></a>
                    <a href="https://www.facebook.com/senaisp.scsmeca/"><i class="fa-brands fa-facebook"></i></a>
                </div>
            </div>
            <div class="footer-col">
                <h3>NAVEGAÇÃO</h3>
                <ul>
                    <li><a href="#eventos">Eventos</a></li>
                    <li><a href="#sobre">Sobre o Centro</a></li>
                    <li><a href="#impactos">Impactos</a></li>
                    <li><a href="#galeria">Galeria</a></li>
                    <li><a href="#contato">Contato</a></li>
                </ul>
            </div>
            <div class="footer-col">
                <h3>CONTATO</h3>
                <ul>
                    <li><i class="fa-solid fa-phone"></i> (11) 3551-8291</li>
                    <li><i class="fa-solid fa-envelope"></i> senai@email.com</li>
                    <li><i class="fa-solid fa-globe"></i> www.aluno.senai.br</li>
                    <li><i class="fa-solid fa-location-dot"></i> Rua Niterói, 180<br>Centro, São Caetano do Sul - SP<br>CEP: 09510-200</li>
                </ul>
            </div>
            <div class="footer-col">
                <h3>LINKS ÚTEIS</h3>
                <ul>
                    <li><a href="#">Política de Privacidade</a></li>
                    <li><a href="#">Perguntas Frequentes</a></li>
                    <li><a href="#">Centro de Eventos</a></li>
                </ul>
            </div>
        </div>
    </footer>

    <!-- ==========================================================================
         WIDGET FLUTUANTE CHATBOT GEMINI NEON (INJETADO AQUI)
         ========================================================================== -->
    <!-- Botão Flutuante (Bubble) -->
    <div class="chatbot-bubble" id="chatbotBubble" title="Tire suas dúvidas!">
        <i class="fa-regular fa-comments"></i>
    </div>

    <!-- Janela de Conversa Flutuante -->
    <div class="chatbot-window" id="chatbotWindow">
        <div class="chatbot-header">
            <div class="chatbot-header-info">
                <div class="chatbot-avatar"><i class="fa-solid fa-robot"></i></div>
                <div class="chatbot-header-text">
                    <h3>Suporte Paulo Skaf</h3>
                    <span><i class="fa-solid fa-circle" style="font-size: 0.5rem;"></i> Online</span>
                </div>
            </div>
            <button class="chatbot-close-btn" id="chatbotCloseBtn" type="button">&times;</button>
        </div>
       
        <div class="chatbot-body" id="chatbotBody">
            <!-- Mensagens inseridas dinamicamente via JS -->
        </div>
       
        <div class="chatbot-footer">
            <input type="text" id="chatbotInput" placeholder="Digite sua pergunta..." maxlength="200" />
            <button class="chatbot-send-btn" id="chatbotSendBtn" type="button">
                <i class="fa-solid fa-paper-plane"></i>
            </button>
        </div>
    </div>
}

<!-- NOVO MODAL DE DETALHES GLASSMORPHISM LIGHT/WHITE -->
<div id="eventModal" class="ev-modal-overlay" style="display: none;">
    <div class="ev-modal-container">
        <button class="ev-modal-close-btn" id="closeModalBtn" type="button">&times;</button>
       
        <div class="ev-modal-content-wrapper">
            <!-- Lado Esquerdo -->
            <div class="ev-modal-left">
                <div class="ev-modal-image-container">
                    <img id="modalEventImage" src="" alt="Imagem do Evento">
                </div>
            </div>
           
            <!-- Lado Direito -->
            <div class="ev-modal-right">
                <div class="ev-modal-header-row">
                    <h2 class="ev-modal-title" id="modalEventTitle">Título do Evento</h2>
                    <button class="ev-modal-share-btn" type="button"><i class="fa-solid"></i></button>
                </div>
               
                <!-- Grid de Destaques Hexagonais -->
                <div class="ev-modal-highlights-list">
                    <div class="ev-highlight-item-new">
                        <div class="ev-hex-icon-wrapper">
                            <div class="ev-hex-icon"><i class="fa-regular fa-calendar"></i></div>
                        </div>
                        <div class="ev-highlight-text-block">
                            <span class="ev-highlight-label">DATA E HORA</span>
                            <span class="ev-highlight-val" id="modalEventDate">25 de Junho às 03h</span>
                        </div>
                    </div>
                   
                    <div class="ev-highlight-item-new">
                        <div class="ev-hex-icon-wrapper">
                            <div class="ev-hex-icon"><i class="fa-solid fa-location-dot"></i></div>
                        </div>
                        <div class="ev-highlight-text-block">
                            <span class="ev-highlight-label">LOCALIZAÇÃO</span>
                            <span class="ev-highlight-val" id="modalEventLocal">Auditório Central</span>
                        </div>
                    </div>
                   
                    <div class="ev-highlight-item-new">
                        <div class="ev-hex-icon-wrapper">
                            <div class="ev-hex-icon"><i class="fa-solid fa-user"></i></div>
                        </div>
                        <div class="ev-highlight-text-block">
                            <span class="ev-highlight-label">PALESTRANTE</span>
                            <span class="ev-highlight-val" id="modalEventPalestrante">Eng. Ricardo Mendes</span>
                        </div>
                    </div>
                   
                    <div class="ev-highlight-item-new">
                        <div class="ev-hex-icon-wrapper">
                            <div class="ev-hex-icon"><i class="fa-solid fa-display"></i></div>
                        </div>
                        <div class="ev-highlight-text-block">
                            <span class="ev-highlight-label">TIPO DE EVENTO</span>
                            <span class="ev-highlight-val" id="modalEventFormat">Workshop / Palestra</span>
                        </div>
                    </div>
                </div>
               
                <hr class="ev-modal-divider">
               
                <!-- Descrição -->
                <div class="ev-modal-description">
                    <p id="modalEventDescription">Entenda como a implementação de robôs colaborativos...</p>
                </div>
               
                <!-- Ações -->
