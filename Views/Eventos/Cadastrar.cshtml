@model Eventos_ProjetoFinal.Models.Eventos
@{
    ViewData["Title"] = "Criar Evento";
}
@section Styles {
    <link rel="stylesheet" href="~/css/padrao.css" />
    <link rel="stylesheet" href="~/css/header.css" />
    <link rel="stylesheet" href="~/css/aside.css" />
    <link rel="stylesheet" href="~/css/cadastroEvento.css" />
}
<header class="admin-topbar">
    <div class="logo-senai">SENAI</div>
    <div class="admin-profile">
         @if (Context.Session.GetString("Email") != null)
         {
             <span style="color: white; margin-right: 15px;">@Context.Session.GetString("Email")</span>
             <a asp-controller="Login" asp-action="Logout" style="color: white; text-decoration: none;"><i class="fa-solid fa-right-from-bracket"></i> Sair</a>
         }
    </div>
</header>
<div class="admin-dashboard-container">
    <aside class="sidebar">
        <div class="logo">SENAI</div>
        <nav class="menu">
            <a asp-controller="Eventos" asp-action="Index" class="menu-item-new"><i class="fa-solid fa-chart-pie"></i> Visão Geral</a>
            <a asp-controller="Eventos" asp-action="Cadastrar" class="menu-item-new active"><i class="fa-solid fa-calendar-plus"></i> Novo Evento</a>
            <a asp-controller="Eventos" asp-action="Galeria" class="menu-item-new"><i class="fa-solid fa-images"></i> Galeria de Eventos</a>
        </nav>
    </aside>
    <main class="admin-main-content">
        <div class="form-header">
            <div class="breadcrumb">Inicio > Gestão de Eventos > <span>Novo Evento</span></div>
        </div>
        <form class="event-form-container" asp-controller="Eventos" asp-action="Cadastrar" method="post">
            <h1 class="form-main-title">Criação de <span style="color: #d9383a;">Novo Evento</span></h1>
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            
            <div class="form-section-new">
                <h2>1. Informações Básicas</h2>
                
                <div class="input-field-group">
                    <label asp-for="NomeEvento">Título do evento:</label>
                    <input asp-for="NomeEvento" type="text" placeholder="Insira o título aqui..." required />
                    <span asp-validation-for="NomeEvento" class="text-danger"></span>
                </div>
                <div class="input-field-grid-2">
                    <div class="input-field-group">
                        <label asp-for="TipoEvento">Tipo de evento:</label>
                        <div class="select-wrapper">
                            <select asp-for="TipoEvento" required>
                                <option value="Workshop">Workshop</option>
                                <option value="Palestra">Palestra</option>
                            </select>
                        </div>
                        <span asp-validation-for="TipoEvento" class="text-danger"></span>
                    </div>
                    
                    <div class="input-field-group">
                        <label asp-for="CapacidadeEvento">Capacidade:</label>
                        <input asp-for="CapacidadeEvento" type="number" required />
                        <span asp-validation-for="CapacidadeEvento" class="text-danger"></span>
                    </div>
                </div>
                <div class="input-field-group">
                    <label asp-for="LocalEvento">Local do evento:</label>
                    <input asp-for="LocalEvento" type="text" placeholder="Insira o local aqui..." required />
                    <span asp-validation-for="LocalEvento" class="text-danger"></span>
                </div>
                <div class="input-field-group">
                    <label asp-for="Descricao">Descrição do Evento:</label>
                    <textarea asp-for="Descricao" placeholder="Insira a descrição detalhada do evento aqui..."></textarea>
                    <span asp-validation-for="Descricao" class="text-danger"></span>
                </div>
            </div>
            <div class="form-section-new">
                <h2>2. Datas e Carga Horária</h2>
                <div class="input-field-grid-3">
                    <div class="input-field-group">
                        <label asp-for="DataEvento">Data</label>
                        <div class="input-with-icon">
                            <input asp-for="DataEvento" type="date" required />
                            <i class="fa-regular fa-calendar field-icon-light"></i>
                        </div>
                        <span asp-validation-for="DataEvento" class="text-danger"></span>
                    </div>
                    
                    <div class="input-field-group">
                        <label asp-for="HorarioEvento">Horário</label>
                        <div class="input-with-icon">
                            <input asp-for="HorarioEvento" type="datetime-local" required />
                            <i class="fa-regular fa-clock field-icon-light"></i>
                        </div>
                        <span asp-validation-for="HorarioEvento" class="text-danger"></span>
                    </div>
                    
                    <div class="input-field-group">
                        <label asp-for="CargaHorariaEvento">Carga Horária</label>
                        <input asp-for="CargaHorariaEvento" type="text" placeholder="ex. 4 horas" required />
                        <span asp-validation-for="CargaHorariaEvento" class="text-danger"></span>
                    </div>
                </div>
            </div>
            <div class="form-section-new">
                <h2>3. Status e Palestrante</h2>
                <div class="input-field-grid-2">
                    <div class="input-field-group">
                        <label asp-for="StatusEvento">Status</label>
                        <div class="select-wrapper">
                            <select asp-for="StatusEvento" required>
                                <option value="Ativo">Ativo</option>
                                <option value="Inativo">Inativo</option>
                                <option value="Pendente">Pendente</option>
                            </select>
                        </div>
                        <span asp-validation-for="StatusEvento" class="text-danger"></span>
                    </div>
                    
                    <div class="input-field-group">
                        <label asp-for="NomePalestrante">Palestrante</label>
                        <input asp-for="NomePalestrante" type="text" placeholder="Nome do palestrante" required />
                        <span asp-validation-for="NomePalestrante" class="text-danger"></span>
                    </div>
                </div>
            </div>
            <div class="form-submit-actions">
                <button type="submit" class="btn-save-publish-dark">Salvar e Publicar</button>
                <a asp-controller="Eventos" asp-action="Index" class="btn-cancel-light">Cancelar</a>
            </div>
        </form>
    </main>
</div>